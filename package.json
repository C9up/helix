{
	"name": "@c9up/helix",
	"version": "0.1.0",
	"description": "Helix — unified testing toolkit for the Ream ecosystem (bus + http + db fakes, fluent assertions, container overrides, time-travel)",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"helix": "bin/helix.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"development": "./src/index.ts",
			"import": "./dist/index.js"
		},
		"./bus": {
			"types": "./dist/bus/index.d.ts",
			"development": "./src/bus/index.ts",
			"import": "./dist/bus/index.js"
		},
		"./http": {
			"types": "./dist/http/index.d.ts",
			"development": "./src/http/index.ts",
			"import": "./dist/http/index.js"
		},
		"./logger": {
			"types": "./dist/logger/index.d.ts",
			"development": "./src/logger/index.ts",
			"import": "./dist/logger/index.js"
		},
		"./mail": {
			"types": "./dist/mail/index.d.ts",
			"development": "./src/mail/index.ts",
			"import": "./dist/mail/index.js"
		},
		"./nova": {
			"types": "./dist/nova/index.d.ts",
			"development": "./src/nova/index.ts",
			"import": "./dist/nova/index.js"
		},
		"./queue": {
			"types": "./dist/queue/index.d.ts",
			"development": "./src/queue/index.ts",
			"import": "./dist/queue/index.js"
		},
		"./relay": {
			"types": "./dist/relay/index.d.ts",
			"development": "./src/relay/index.ts",
			"import": "./dist/relay/index.js"
		},
		"./storage": {
			"types": "./dist/storage/index.d.ts",
			"development": "./src/storage/index.ts",
			"import": "./dist/storage/index.js"
		},
		"./db": {
			"types": "./dist/db/index.d.ts",
			"development": "./src/db/index.ts",
			"import": "./dist/db/index.js"
		},
		"./container": {
			"types": "./dist/container/index.d.ts",
			"development": "./src/container/index.ts",
			"import": "./dist/container/index.js"
		},
		"./time": {
			"types": "./dist/time/index.d.ts",
			"development": "./src/time/index.ts",
			"import": "./dist/time/index.js"
		},
		"./runtime": {
			"types": "./dist/runtime/index.d.ts",
			"development": "./src/runtime/index.ts",
			"import": "./dist/runtime/index.js"
		},
		"./runtime/worker": {
			"types": "./dist/runtime/worker.d.ts",
			"development": "./src/runtime/worker.ts",
			"import": "./dist/runtime/worker.js"
		},
		"./bin/helix.js": "./bin/helix.js"
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"test": "vitest run",
		"test:self": "node bin/helix.js test tests/selftest --timeout=30000",
		"lint": "biome check src/",
		"test:coverage": "vitest run --coverage",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@types/node": "*",
		"typescript": "^6.0.2"
	},
	"peerDependencies": {
		"@c9up/atlas": "workspace:*",
		"@c9up/pulsar": "workspace:*",
		"@c9up/ream": "workspace:*"
	},
	"files": [
		"src",
		"dist",
		"README.md",
		"LICENSE"
	]
}
